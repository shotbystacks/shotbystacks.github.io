# Shot By Stacks — Version 2

Responsive photography portfolio for Rrya “Stacks” Harris.

## Pages
- `index.html`: home, perspective, portfolio and contact
- `about.html`: separate About page

## Preview
Open `index.html` in a browser. Keep the `images` folder beside the HTML files.

## Publish
Upload the entire extracted `shot-by-stacks` folder to Netlify, GitHub Pages, or your web host.


## Amendment
Portfolio filters removed. Availability list simplified to Corporate and Travel, with BTS removed.


## Final amendment
Removed Corporate and Travel from the Available For section.

const menuButton = document.querySelector('.menu-toggle');
const nav = document.querySelector('#site-nav');

if (menuButton && nav) {
  menuButton.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    menuButton.setAttribute('aria-expanded', String(open));
  });
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    nav.classList.remove('open');
    menuButton.setAttribute('aria-expanded', 'false');
  }));
}


const dialog = document.querySelector('.lightbox');
if (dialog) {
  const dialogImage = dialog.querySelector('img');
  document.querySelectorAll('.work-card').forEach(card => card.addEventListener('click', () => {
    dialogImage.src = card.dataset.full;
    dialogImage.alt = card.querySelector('img').alt;
    dialog.showModal();
  }));
  dialog.querySelector('.lightbox-close').addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', e => {
    if (e.target === dialog) dialog.close();
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && dialog.open) dialog.close();
  });
}

const year = document.querySelector('#year');
if (year) year.textContent = new Date().getFullYear();

:root {
  --bg: #0a0a0a;
  --surface: #111;
  --text: #f5f2ec;
  --muted: #aaa6a0;
  --line: rgba(255,255,255,.16);
  --accent: #f5f2ec;
  --max: 1440px;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0; background: var(--bg); color: var(--text);
  font-family: Arial, Helvetica, sans-serif; line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
img { display:block; max-width:100%; }
button, a { font: inherit; }
a { color: inherit; }
.site-header {
  position: fixed; z-index: 20; top:0; left:0; width:100%;
  display:flex; align-items:center; justify-content:space-between;
  padding: 22px clamp(20px,4vw,64px);
  background: linear-gradient(to bottom, rgba(0,0,0,.72), transparent);
}
.solid-header { background:rgba(10,10,10,.96); border-bottom:1px solid var(--line); }
.wordmark { font-weight:800; letter-spacing:.12em; text-decoration:none; font-size:.9rem; }
.site-header nav { display:flex; gap:28px; }
.site-header nav a { text-decoration:none; font-size:.82rem; letter-spacing:.1em; text-transform:uppercase; }
.site-header nav a[aria-current="page"] { border-bottom:1px solid currentColor; }
.menu-toggle { display:none; color:white; background:none; border:1px solid var(--line); padding:8px 12px; }
.hero { min-height:100svh; position:relative; display:grid; align-items:end; overflow:hidden; }
.hero > img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 48%; }
.hero-overlay { position:absolute; inset:0; background:linear-gradient(90deg,rgba(0,0,0,.82) 0%,rgba(0,0,0,.35) 50%,rgba(0,0,0,.1)),linear-gradient(0deg,rgba(0,0,0,.75),transparent 45%); }
.hero-copy { position:relative; z-index:2; width:min(800px,92%); padding:0 clamp(20px,6vw,92px) clamp(54px,8vw,110px); }
.eyebrow,.section-kicker { text-transform:uppercase; letter-spacing:.18em; font-size:.74rem; font-weight:700; }
.hero h1 { font-size:clamp(3.4rem,9vw,8.5rem); line-height:.83; letter-spacing:-.07em; margin:.22em 0; }
.hero-copy > p:not(.eyebrow) { max-width:680px; color:#ddd8d0; font-size:clamp(1rem,1.5vw,1.25rem); }
.button {
  display:inline-flex; margin-top:22px; padding:13px 18px;
  border:1px solid rgba(255,255,255,.55); text-decoration:none;
  text-transform:uppercase; letter-spacing:.12em; font-size:.72rem;
  transition:.2s ease;
}
.button:hover { background:white; color:#090909; }
.section { max-width:var(--max); margin:auto; padding:clamp(80px,10vw,150px) clamp(20px,5vw,72px); }
.intro { display:grid; grid-template-columns:1fr 2fr; gap:40px; align-items:start; }
.intro h2,.section-heading h2,.about-name,.contact-section h2 { font-size:clamp(2.7rem,6vw,6rem); letter-spacing:-.055em; line-height:.95; margin:0; }
.intro .lead {
  font-size:clamp(1rem,1.5vw,1.25rem);
  max-width:760px;
  color:#cbc6bf;
  margin:0;
}
.section-heading { display:flex; justify-content:space-between; align-items:end; gap:30px; margin-bottom:40px; }
.portfolio-grid { columns:3 320px; column-gap:14px; }
.work-card {
  display:block; position:relative; width:100%; margin:0 0 14px; padding:0;
  border:0; background:none; cursor:zoom-in; break-inside:avoid; overflow:hidden; color:white; text-align:left;
}
.work-card img { width:100%; transition:transform .45s ease; }
.work-card:hover img { transform:scale(1.018); }
.work-card[hidden] { display:none; }
.about-page main { padding-top:78px; }
.about-section { display:grid; grid-template-columns:1.05fr .95fr; gap:clamp(40px,8vw,120px); align-items:center; }
.standalone-about { min-height:calc(100svh - 78px); }
.about-images { position:relative; padding:0 15% 13% 0; }
.about-primary { width:80%; aspect-ratio:3/4; object-fit:cover; filter:grayscale(1); }
.about-secondary { position:absolute; width:48%; right:0; bottom:0; border:8px solid var(--bg); }
.about-name { font-style:italic; }
.about-copy p { color:#c8c4bd; font-size:1.08rem; max-width:690px; }
.availability { margin-top:34px; border-top:1px solid var(--line); padding-top:22px; }
.availability span { font-size:.72rem; text-transform:uppercase; letter-spacing:.16em; color:#fff; }
.contact-section { padding:clamp(90px,12vw,180px) clamp(20px,8vw,120px); background:#ece8df; color:#0b0b0b; }
.contact-section p { max-width:720px; font-size:1.12rem; }
.contact-actions { display:flex; align-items:center; gap:28px; flex-wrap:wrap; }
.button.light { border-color:#111; }
.button.light:hover { background:#111; color:white; }
.text-link { text-underline-offset:5px; }
footer { display:flex; justify-content:space-between; gap:20px; padding:26px clamp(20px,4vw,64px); font-size:.8rem; color:var(--muted); }
.lightbox {
  width:100vw; height:100vh; max-width:none; max-height:none; padding:0; border:0;
  background:rgba(0,0,0,.94); overflow:hidden;
}
.lightbox::backdrop { background:rgba(0,0,0,.94); }
.lightbox img { width:100%; height:100%; object-fit:contain; padding:3vw; }
.lightbox-close { position:fixed; z-index:2; right:22px; top:18px; width:44px; height:44px; color:white; border:1px solid var(--line); background:rgba(0,0,0,.45); font-size:1.7rem; cursor:pointer; }
@media (max-width:760px) {
  .menu-toggle { display:block; }
  .site-header nav {
    display:none; position:absolute; right:20px; top:66px; flex-direction:column; min-width:170px;
    padding:20px; background:#111; border:1px solid var(--line);
  }
  .site-header nav.open { display:flex; }
  .hero h1 { font-size:clamp(3rem,17vw,5.2rem); }
  .intro,.about-section { grid-template-columns:1fr; }
  .section-heading { align-items:start; flex-direction:column; }
  .portfolio-grid { columns:2 145px; column-gap:8px; }
  .work-card { margin-bottom:8px; }
  .about-images { max-width:580px; }
  footer { flex-direction:column; }
}
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior:auto; }
  * { transition:none !important; }
}
